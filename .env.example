# Copy this to .env for local development (never commit .env)

# PostgreSQL — Replit sets these automatically
# DATABASE_URL=postgresql://user:password@localhost:5432/cosmos_chat

# Server port (default: 3001 for local dev, Render sets PORT automatically)
# SERVER_PORT=3001

# Set to "production" on Render (set via Render environment variables UI)
# NODE_ENV=production
